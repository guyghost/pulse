{
  "name": "@pulse/dashboard",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "NODE_OPTIONS=--disable-warning=DEP0205 vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --threshold error"
  },
  "dependencies": {
    "@pulse/domain": "workspace:*",
    "@pulse/ui": "workspace:*",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.106.1",
    "@vercel/microfrontends": "^2.3.3",
    "svelte": "^5.55.9"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@pulse/tsconfig": "workspace:*",
    "@sveltejs/adapter-vercel": "^6.3.2",
    "@sveltejs/kit": "^2.61.1",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@tailwindcss/vite": "^4.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  }
}
