# Public (embedded in client bundle — safe for anon key only)
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
PUBLIC_CHROME_STORE_URL=https://chromewebstore.google.com/search/MissionPulse
PUBLIC_LANDING_URL=https://missionpulse.app

# Private (server-only — set in Vercel Production env, never commit values)
SUPABASE_SERVICE_ROLE_KEY=

# GLM text generation (/api/generate)
GLM_API_KEY=
GLM_MODEL=glm-4-flash

# Lemon Squeezy checkout + webhooks
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_STORE_ID=
LEMON_SQUEEZY_WEBHOOK_SECRET=
LEMON_SQUEEZY_CREDITS_STARTER_VARIANT_ID=
LEMON_SQUEEZY_CREDITS_PRO_VARIANT_ID=
LEMON_SQUEEZY_CREDITS_POWER_VARIANT_ID=

# Optional: cache HTML responses for 5 minutes (performance experiments)
# MISSIONPULSE_PERF_CACHE_HTML=1
# Premium Copilot (internal pilot: flag AND explicit user allowlist required)
COPILOT_SESSION_SIGNING_SECRET=
COPILOT_ROLLOUT_ENABLED=false
COPILOT_ROLLOUT_USER_IDS=
COPILOT_EXTENSION_REDIRECT_URIS=
# Random 16+ character secret injected by Vercel in the receipt-maintenance cron.
CRON_SECRET=

# Eve provider (disabled by default)
MISSIONPULSE_EVE_ENABLED=false
MISSIONPULSE_EVE_BASE_URL=
MISSIONPULSE_EVE_TIMEOUT_MS=60000
