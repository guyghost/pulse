{
  "extends": "@pulse/tsconfig/svelte.json",
  "compilerOptions": {
    "paths": {
      "$lib/*": ["./src/lib/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.svelte",
    "scripts/**/*.ts",
    "vite.config.ts",
    "playwright.config.ts",
    "playwright.extension.config.ts",
    "playwright.mv3.config.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
