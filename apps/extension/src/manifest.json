{
  "manifest_version": 3,
  "name": "MissionPulse",
  "version": "0.1.0",
  "description": "Agent freelance : feed de missions centralisé avec scoring et analyse TJM",
  "minimum_chrome_version": "114",
  "permissions": [
    "sidePanel",
    "storage",
    "cookies",
    "alarms",
    "notifications",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://www.free-work.com/*",
    "https://*.lehibou.com/*",
    "https://hiway-missions.fr/*",
    "https://jhgjtlkfewuiiofxfrvh.supabase.co/*",
    "https://*.collective.work/*",
    "https://app.cherry-pick.io/*"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "action": {
    "default_title": "MissionPulse"
  },
  "icons": {
    "16": "static/icons/icon-16.png",
    "48": "static/icons/icon-48.png",
    "128": "static/icons/icon-128.png"
  }
}
