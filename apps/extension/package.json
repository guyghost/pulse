{
  "name": "@pulse/extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint . --ext .ts,.svelte",
    "lint:fix": "eslint . --ext .ts,.svelte --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "verify-manifest": "tsx scripts/verify-manifest.ts",
    "bump-version": "tsx scripts/bump-version.ts",
    "build:extension": "bash scripts/build-extension.sh",
    "health-check": "tsx tests/health/run-health-checks.ts",
    "health-check:json": "tsx tests/health/run-health-checks.ts --json"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.0",
    "lucide-svelte": "^0.460.0",
    "svelte": "^5.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.49.0",
    "@pulse/tsconfig": "workspace:*",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/chrome": "^0.0.287",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.0.0",
    "eslint-plugin-svelte": "^2.45.0",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.4.0",
    "prettier-plugin-svelte": "^3.3.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.1",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
