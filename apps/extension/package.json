{
  "name": "@pulse/extension",
  "version": "0.2.2",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "NODE_OPTIONS=--disable-warning=DEP0205 vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "pnpm --filter @pulse/ui build && playwright test",
    "test:e2e:full": "pnpm --filter @pulse/ui build && env -u CI playwright test",
    "test:regression": "vitest run tests/unit/regression/parser-regression.test.ts",
    "health-check": "tsx tests/health/run-health-checks.ts",
    "health-check:json": "HEALTH_CHECK_JSON=1 tsx tests/health/run-health-checks.ts --json",
    "lint": "eslint . --ext .ts,.svelte",
    "lint:fix": "eslint . --ext .ts,.svelte --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "verify-manifest": "tsx scripts/verify-manifest.ts",
    "bump-version": "tsx scripts/bump-version.ts",
    "build:extension": "bash scripts/build-extension.sh"
  },
  "dependencies": {
    "@pulse/domain": "workspace:*",
    "@pulse/ui": "workspace:*",
    "@supabase/supabase-js": "^2.110.0",
    "lucide-svelte": "^1.0.1",
    "svelte": "^5.56.4",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.7.1",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.1",
    "@pulse/tsconfig": "workspace:*",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/chrome": "^0.2.2",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^10.7.0",
    "eslint-plugin-svelte": "^2.45.0",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "prettier-plugin-svelte": "^4.1.1",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.4",
    "vitest": "^3.2.6"
  }
}
