{
  "name": "pulse",
  "version": "0.2.1",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "test:watch": "turbo test:watch",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "turbo format",
    "format:check": "turbo format:check",
    "clean": "turbo clean && rm -rf node_modules .turbo",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{ts,svelte}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{css,json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "lint-staged": "^16.4.0",
    "simple-git-hooks": "^2.13.1",
    "turbo": "^2.0.0"
  },
  "pnpm": {
    "overrides": {
      "devalue": ">=5.6.4",
      "picomatch": ">=4.0.4",
      "rollup": ">=4.0.0"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
