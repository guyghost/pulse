{
  "$schema": "https://v2-10-5.turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "PUBLIC_CHROME_STORE_URL",
        "PUBLIC_LANDING_URL",
        "PUBLIC_SUPABASE_ANON_KEY",
        "PUBLIC_SUPABASE_URL",
        "CONNECTORS_INCLUDE",
        "CONNECTORS_EXCLUDE"
      ],
      "outputs": ["dist/**", ".svelte-kit/**", ".vercel/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "cache": false
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "format": {
      "cache": false
    },
    "format:check": {},
    "test:e2e": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "test:e2e:full": {
      "dependsOn": ["^build"],
      "cache": false
    }
  }
}
